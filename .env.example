# =============================================================================
# Alsintan — contoh environment untuk pengujian lokal
# =============================================================================
# Cara pakai:
#   1. Salin file ini:  copy .env.example .env   (Windows: copy .env.example .env)
#   2. Generate APP_KEY:  php artisan key:generate
#   3. (Opsional) JWT_SECRET — lihat bagian JWT di bawah
#   4. Migrasi:  php artisan migrate
#   5. User admin:  php artisan user:create admin@contoh.id --name="Admin" --password=rahasia123 --role=admin
# =============================================================================

APP_NAME=Alsintan
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# URL harus cocok dengan host saat tes API / Flutter (mis. http://127.0.0.1:8000)
APP_URL=http://127.0.0.1:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Database — pengembangan cepat: SQLite (default Laravel)
# -----------------------------------------------------------------------------
DB_CONNECTION=sqlite
# Untuk SQLite: biarkan DB_DATABASE & DB_HOST kosong — Laravel pakai database/database.sqlite

# Alternatif MySQL / MariaDB (uncomment & sesuaikan):
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=alsintan
# DB_USERNAME=root
# DB_PASSWORD=

# -----------------------------------------------------------------------------
# Session & cache (disarankan database agar session web + queue konsisten)
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Mail — lupa password (OTP dikirim lewat email)
# -----------------------------------------------------------------------------
# Pengujian cepat: OTP muncul di storage/logs/laravel.log (tidak kirim email sungguhan)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@localhost"
MAIL_FROM_NAME="${APP_NAME}"

# Untuk tes kirim email sungguhan (Mailtrap, Gmail app password, dll):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
# MAIL_ENCRYPTION=tls

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# JWT — API mobile (Flutter) & refresh token
# -----------------------------------------------------------------------------
# Disarankan set JWT_SECRET eksplisit (jangan commit nilai asli ke git).
# Generate contoh:  php -r "echo bin2hex(random_bytes(32)).PHP_EOL;"
JWT_SECRET=
JWT_ALGO=HS256
JWT_ISSUER="${APP_NAME}"
JWT_AUDIENCE=alsintan-mobile
# Access token (detik): default 900 = 15 menit
JWT_ACCESS_TTL=900
# Refresh token (detik): default 2592000 = 30 hari
JWT_REFRESH_TTL=2592000
JWT_LEEWAY=30

# -----------------------------------------------------------------------------
# Laravel Reverb (WebSocket) — opsional, bisa dikosongkan jika belum dipakai
# -----------------------------------------------------------------------------
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
